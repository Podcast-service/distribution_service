# Distribution Service configuration

# Postgres connection (read-only role recommended for prod)
DATABASE_URL=postgres://podcast_user:podcast_pass@localhost:5433/podcast_db

# HTTP server bind
BIND_ADDR=0.0.0.0:8788

# Public base URL — used as a fallback when building absolute links
# (e.g. <link>, <itunes:image href=...>) if values stored in DB are not absolute.
# In production this is the host that serves the RSS endpoint.
PUBLIC_BASE_URL=http://localhost:8788

# Logging
RUST_LOG=distribution_service=info,tower_http=info,sqlx=warn

# Connection pool
DB_MAX_CONNECTIONS=10
DB_CONNECT_TIMEOUT_SECONDS=5
